# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ------------------------------------------------------------------
# META MARKETING API (real account connection — "traficker" features)
# Optional. Without these the "Cuenta Meta Ads" tab stays in demo mode.
# How to get each value: see the "Conectar tu cuenta real de Meta Ads"
# section in README.md.
# ------------------------------------------------------------------

# Long-lived access token with the ads_management + ads_read permissions.
# Generate it from a System User in Meta Business Suite
# (Business Settings > Users > System Users > Generate New Token).
META_ACCESS_TOKEN="MY_META_ACCESS_TOKEN"

# The ad account you want to manage. Accepts either the raw numeric ID
# or the "act_..." form — the app prefixes it with "act_" automatically.
META_AD_ACCOUNT_ID="1234567890"

# Optional but recommended if Graph API Explorer does not return /me/accounts.
META_PAGE_ID="123456789012345"
META_PAGE_NAME="Femly Probiotics"

# Optional — only needed if you plan to extend this app with OAuth login
# flows or webhook subscriptions via your own Meta App.
META_APP_ID=""
META_APP_SECRET=""

# ------------------------------------------------------------------
# OMNICHANNEL OPERATIONS (Mastershop + WhatsApp + reporting)
# ------------------------------------------------------------------

# Mastershop adapter. Use the endpoint paths from your Mastershop API contract.
MASTERSHOP_API_BASE_URL="https://api.mastershop.example.com"
MASTERSHOP_API_TOKEN="MY_MASTERSHOP_TOKEN"
MASTERSHOP_STORE_ID=""
MASTERSHOP_REPORTS_PATH="/reports/daily"
MASTERSHOP_WEBHOOK_SECRET="MY_MASTERSHOP_WEBHOOK_SECRET"

# WhatsApp Business Cloud API.
WHATSAPP_GRAPH_VERSION="v21.0"
WHATSAPP_ACCESS_TOKEN="MY_WHATSAPP_ACCESS_TOKEN"
WHATSAPP_PHONE_NUMBER_ID="MY_WHATSAPP_PHONE_NUMBER_ID"
WHATSAPP_VERIFY_TOKEN="MY_WHATSAPP_VERIFY_TOKEN"
WHATSAPP_ALERT_TO="573001112233"

# Optimization thresholds used by consolidated reports and alerts.
OMNICHANNEL_MIN_ROAS="1.5"
OMNICHANNEL_TARGET_ROAS="3"
